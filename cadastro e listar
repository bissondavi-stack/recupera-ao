from validaçoes import *
import json


alunos = []

def cadastrar_aluno():

    nome = input("Digite o nome do aluno: ")

    if not validar_texto(nome):
        print("Nome inválido.")
        return

    idade = input("Digite a idade do aluno: ")

    if not validar_numero(idade):
        print("Idade inválida.")
        return

    turma = input("Digite a turma do aluno (1 a 3): ")

    if not validar_turma(turma):
        print("turma inválida.")
        return

    nota1 = int(input("Digite a primeira nota do aluno : "))
    nota2 = int(input("Digite a segunda nota do aluno : "))
    nota3 = int(input("Digite a terceira nota do aluno : "))


    media = nota1 + nota2 + nota3
    mediaF = media / 3

    if mediaF > 7:
        situaçao = "aprovado"
    elif mediaF < 5:
        situaçao = "reprovado"
    else:
        situaçao = "reculperaçao"

    dado = {
        "nome": nome,
        "idade": idade,
        "turma": turma,    
        "media": mediaF,
        "situaçao": situaçao,    
            }

    alunos.append(dado)

    with open("dados.json", "w", encoding="utf-8") as arquivo:
        json.dump(alunos, arquivo, ensure_ascii=False, indent=4)

    print("Dados salvos com sucesso")


def listar_alunos():
    with open("dados.json", "r", encoding="utf-8") as arquivo:
            dados = json.load(arquivo)
        
    print("\n=== Dados Salvos ===\n")
    for i, dado in enumerate(dados, 1):
            print(f"Aluno {i}:")
            for chave, valor in dado.items():
                print(f"   {chave}: {valor}")
            print("-" * 25)

