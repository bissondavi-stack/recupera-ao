def validar_texto(texto):

    if texto.strip() == "":
        return False

    if any(char.isdigit() for char in texto):
        return False

    return True


def validar_numero(numero):

    if numero.strip() == "":
        return False

    try:
        float(numero)
        return True

    except:
        return False

def validar_nota(nota):
    try:
        nota = float(nota)
        return 0 <= nota <= 10
    except:
        return False

def validar_turma(turma):
    return turma.isdigit() and 1 <= int(turma) <= 4

def validar_inteiro(valor):
    return valor.isdigit()
